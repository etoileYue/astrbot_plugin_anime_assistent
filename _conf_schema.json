{
  "bangumi_access_token": {
    "description": "Bangumi Access Token",
    "type": "string",
    "hint": "在 https://next.bgm.tv/demo/access-token 获取个人访问令牌"
  },
  "use_cn_mirror": {
    "description": "使用国内镜像（api.bangumi.one）",
    "type": "bool",
    "default": false
  },
  "check_interval_hours": {
    "description": "番剧更新检查间隔（小时）",
    "type": "float",
    "default": 2.0,
    "slider": {"min": 0.5, "max": 24, "step": 0.5}
  },
  "max_interview_rounds": {
    "description": "访谈最大追问轮数",
    "type": "int",
    "default": 3
  },
  "web_viewer_port": {
    "description": "Web 笔记查看器端口（0 禁用）",
    "type": "int",
    "default": 58080
  }
}
